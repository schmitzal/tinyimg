{
    "name": "schmitzal/tinyimg",
    "description": "Image compression for all pngs and jpgs uploaded to the backend (using the tinypng API)",
    "type": "typo3-cms-extension",
    "version": "1.8.1",
    "keywords": [
        "image",
        "compression",
        "tinypng",
        "tinyjpg",
        "tinify"
    ],
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "Alessandro Schmitz",
            "role": "Developer",
            "homepage": "https://www.open.de/"
        }
    ],
    "support": {
        "issues": "https://github.com/schmitzal/tinyimg/issues"
    },
    "require": {
        "php": "^8.4",
        "typo3/cms-core": "^14.2",
        "typo3/cms-extbase": "^13.4 || ^14.2",
        "typo3/cms-filelist": "^13.4 || ^14.2",
        "tinify/tinify": "^1.6"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^4.0",
        "ssch/typo3-rector": "^v3.13"
    },
    "autoload": {
        "psr-4": {
            "Schmitzal\\Tinyimg\\": "Classes"
        }
    },
    "replace": {
        "typo3-ter/tinyimg": "self.version"
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "tinyimg",
            "web-dir": ".Build/Web"
        }
    },
    "config": {
        "allow-plugins": {
            "typo3/cms-composer-installers": true,
            "typo3/class-alias-loader": true
        }
    }
}
